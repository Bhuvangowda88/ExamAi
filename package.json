{
  "name": "interview-assistant",
  "version": "1.0.0",
  "description": "A desktop interview assistant",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "npm run build && electron-builder --mac dmg",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-vite": "^5.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.quicknotes.app",
    "productName": "Interview Assistant",
    "files": ["out/**/*"],
    "directories": {"output": "release"},
    "mac": {"target": "dmg"},
    "win": {"target": "nsis"}
  }
}
